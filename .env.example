# --- Frontend ---
NEXT_PUBLIC_API_BASE=http://localhost:8000

# --- Backend ---
DATA_ROOT=/data
MAX_UPLOAD_MB=2048

# --- Worker defaults ---
# Extra args are passed verbatim to the Nerfstudio CLI commands.
# Keep these empty if you're not sure; use `ns-train <method> --help` inside the worker container to explore options.
NS_TRAIN_EXTRA_ARGS=
NS_RENDER_INTERPOLATE_EXTRA_ARGS=
NS_RENDER_SPIRAL_EXTRA_ARGS=

# Exports (1 = enabled, 0 = disabled)
EXPORT_POINTCLOUD=1
EXPORT_TSDF=1
EXPORT_POISSON=0
RENDER_INTERPOLATE=1
RENDER_SPIRAL=1
